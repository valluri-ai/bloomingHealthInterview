# OpenAI is used for embeddings and merge analysis.
OPENAI_API_KEY=

# Use a Neo4j Sandbox Graph Data Science instance:
# https://sandbox.neo4j.com/
NEO4J_URI=neo4j+s://<host>
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Leave PROMPT_S3_BUCKET empty for local filesystem storage.
# Set it only if you explicitly want S3-backed prompt documents locally.
PROMPT_S3_BUCKET=
PROMPT_S3_PREFIX=prompts
PROMPT_STORE_ROOT=tmp/prompt_store

BENCHMARK_DATASET_PATH=tmp/benchmark-dataset-1000.json
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
MERGE_ANALYSIS_MODEL=openai:gpt-4o-mini
HYBRID_RANKER=rrf
HYBRID_RRF_K=60
HYBRID_CANDIDATE_MULTIPLIER=5
# AWS_REGION is still used for any AWS-backed integrations, but local prompt storage does not require AWS.
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
AWS_REGION=us-east-1
